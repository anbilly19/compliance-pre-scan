# Copy to .env and adjust as needed

# ── Audit DB ──────────────────────────────────────────────────────────────────
# DB_PATH=data/compliance.db

# ── Warn thresholds ───────────────────────────────────────────────────────────
# PII_WARN_THRESHOLD=1
# SECRET_WARN_THRESHOLD=1
# KEYWORD_WARN_THRESHOLD=1

# ── BLOCK thresholds ──────────────────────────────────────────────────────────
# BLOCK_ON_SECRET=1
# BLOCK_ON_PII=0
# BLOCK_ON_STRUCTURAL_ANOMALY=true

# ── Hit masking ───────────────────────────────────────────────────────────────
# MASK_SNIPPETS=false

# ── OPA / Rego policy engine ──────────────────────────────────────────────────
# Leave OPA_URL unset (default) to use the inline Python fallback.
# Set to your OPA server base URL to use Rego for policy decisions.
# The Rego policy file is at config/policy/compliance.rego.
#
# OPA_URL=http://localhost:8181
# OPA_TIMEOUT_S=2.0

# ── Anomaly heuristics ────────────────────────────────────────────────────────
# ENTROPY_HIGH_THRESHOLD=7.2
# SIZE_RATIO_THRESHOLD=50.0
# MAX_ARCHIVE_DEPTH=2

# ── Export ────────────────────────────────────────────────────────────────────
# EXPORT_PSEUDONYMISE_USERS=false

# ── Keyword config ────────────────────────────────────────────────────────────
# KEYWORD_CONFIG_PATHS=config/keywords.yml
