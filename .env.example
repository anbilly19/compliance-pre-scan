# Copy to .env and adjust as needed

# ── Audit DB ──────────────────────────────────────────────────────────────────
# DB_PATH=data/compliance.db

# ── Warn thresholds (ALLOW_WITH_WARNING when hit count >= threshold) ──────────
# PII_WARN_THRESHOLD=1
# SECRET_WARN_THRESHOLD=1
# KEYWORD_WARN_THRESHOLD=1

# ── BLOCK thresholds (HTTP 451 when hit count >= threshold) ───────────────────
# BLOCK_ON_SECRET=1
# BLOCK_ON_PII=0
# BLOCK_ON_STRUCTURAL_ANOMALY=true

# ── Hit masking ───────────────────────────────────────────────────────────────
# false (default) — full snippets returned; useful for dev/testing
# true            — snippets masked before DB write + API response; use in production
#
# Masking rules:
#   PII     → keep first 2 + last 2 chars  e.g. 'max.mustermann@firma.de' → 'ma***de'
#   SECRET  → keep first 4 chars only      e.g. 'AKIAIOSFODNN7EXAMPLE'   → 'AKIA****'
#   KEYWORD → unchanged (the keyword is not sensitive payload)
#   ANOMALY → unchanged (MIME type names / heuristic labels)
# MASK_SNIPPETS=false

# ── Anomaly heuristics ────────────────────────────────────────────────────────
# ENTROPY_HIGH_THRESHOLD=7.2
# SIZE_RATIO_THRESHOLD=50.0
# MAX_ARCHIVE_DEPTH=2

# ── Export ────────────────────────────────────────────────────────────────────
# EXPORT_PSEUDONYMISE_USERS=false

# ── Keyword config ────────────────────────────────────────────────────────────
# KEYWORD_CONFIG_PATHS=config/keywords.yml
