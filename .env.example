# compliance-pre-scan environment config
# Copy to .env and adjust values

# SQLite DB path (relative to project root)
DB_PATH=./compliance_audit.db

# Policy thresholds
PII_WARN_THRESHOLD=1        # warn if PII matches >= this number
SECRET_WARN_THRESHOLD=1     # warn if secret matches >= this number
ANOMALY_ENTROPY_THRESHOLD=7.2  # Shannon entropy flag (0–8 scale)
ANOMALY_SIZE_RATIO=10       # flag if bytes-per-char ratio exceeds this

# Pseudonymise user IDs in Betriebsrat CSV export (true/false)
EXPORT_PSEUDONYMISE_USERS=true

# Rules directories
KEYWORD_RULES_DIR=./rules/keywords
SECRET_RULES_FILE=./rules/secrets/patterns.yaml
