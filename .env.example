# Copy to .env and adjust as needed

# ── Audit DB ──────────────────────────────────────────────────────────────────
# DB_PATH=data/compliance.db

# ── Warn thresholds (ALLOW_WITH_WARNING when hit count >= threshold) ──────────
# PII_WARN_THRESHOLD=1
# SECRET_WARN_THRESHOLD=1
# KEYWORD_WARN_THRESHOLD=1

# ── BLOCK thresholds (HTTP 451 when hit count >= threshold) ──────────────────
# Set to 0 to disable blocking for that category.
#
# Block on any secret hit (default: 1 = enabled)
# BLOCK_ON_SECRET=1
#
# Block when PII hits reach this count (default: 0 = warn only, never hard-block)
# BLOCK_ON_PII=0
#
# Block when any HIGH structural anomaly is detected (ext mismatch, entropy spike)
# BLOCK_ON_STRUCTURAL_ANOMALY=true

# ── Anomaly heuristics ────────────────────────────────────────────────────────
# ENTROPY_HIGH_THRESHOLD=7.2
# SIZE_RATIO_THRESHOLD=50.0
# MAX_ARCHIVE_DEPTH=2

# ── Export ────────────────────────────────────────────────────────────────────
# EXPORT_PSEUDONYMISE_USERS=false

# ── Keyword config ────────────────────────────────────────────────────────────
# KEYWORD_CONFIG_PATHS=config/keywords.yml
